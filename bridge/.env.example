# Copy to .env and fill in. .env is gitignored.
#
# This package is a stdio MCP server exposing the notes vault to an MCP client
# (Hermes Agent, Claude Desktop, Claude Code, ...). The client normally injects
# these env vars when it spawns the server — see the register command below —
# and .env is only used for standalone/manual runs.

# Absolute path to your vault folder — same path shown in the app under
# Settings > Files > Vault folder.
VAULT_ROOT=/absolute/path/to/your/vault

# Mirror these from the app's Settings > Daily notes (no live link to the app,
# so keep them in sync by hand if you change them there). DAILY_TEMPLATE MUST be
# quoted — it contains a '#', which dotenv treats as a comment and would otherwise
# truncate the value at the '# {{date}}' heading.
DAILY_FOLDER=Daily
DAILY_TEMPLATE="---\ntags: [daily]\n---\n# {{date}}\n\n"

# Master switch for the write tools (create_note, append_daily_note, add_task,
# complete_task). Default off: when false they are neither advertised to the
# client nor executed if called anyway.
ALLOW_WRITES=false

# Register with Hermes (stdio). Uses the local tsx binary by absolute path to
# avoid npx resolution flakiness:
#
#   hermes mcp add notes-vault \
#     --command /abs/path/to/bridge/node_modules/.bin/tsx \
#     --args /abs/path/to/bridge/src/mcp.ts \
#     --env VAULT_ROOT=/abs/path/to/vault ALLOW_WRITES=false
