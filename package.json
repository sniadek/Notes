{
  "name": "notes-monorepo",
  "private": true,
  "scripts": {
    "test": "npm --prefix app test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test --debug",
    "test:e2e:report": "playwright test && npm run allure:report",
    "allure:generate": "npm --prefix app run allure:generate",
    "allure:report": "allure generate ./allure-results --clean -o ./allure-report || true && allure open ./allure-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-playwright": "^2.10.5",
    "playwright": "^1.61.1"
  }
}
